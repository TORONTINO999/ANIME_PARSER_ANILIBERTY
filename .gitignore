# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
env/
venv/
ENV/
.venv/

# --- IDE & Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Environment Variables & Secrets ---
.env
.env.local
.env.*.local

# --- Cache & Temp ---
parse_cache.json
*.cache
.cache/
*.tmp
*.temp

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Large Media Files (Mirrors) ---
# Игнорируем тяжелые постеры, но оставляем метаданные и плейлисты
mirrors/*/poster_*.jpg
mirrors/*/poster_*.png
mirrors/*/poster_*.webp

# --- Exceptions (Whitelist) ---
# Явно разрешаем эти файлы, даже если они попадают под другие правила или лежат в игнорируемых папках
!*.m3u8
!mirrors/*/README.md
!mirrors/metadata.json
